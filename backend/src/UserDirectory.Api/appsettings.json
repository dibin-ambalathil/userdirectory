{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/app.db"
  },
  "Auth": {
    "Issuer": "UserDirectory.Api",
    "Audience": "user-directory-api",
    "LocalJwtKey": "",
    "TokenExpirationMinutes": 120,
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "LoginRateLimitPerMinute": 10,
    "RequireHttpsMetadata": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://localhost:3000",
      "https://udtest.netlify.app"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
